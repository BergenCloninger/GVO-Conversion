Function MotorInit : boolean;
var
	ymaxaccel,ymaxvl,xmaxaccel,xmaxvl : string;
	Initstring : string;
Label Cont;
Begin
	MotorInit := True;
	Errmsg := '';
	CommRecord.CommPortNumber := strtoint(PFCIniFile.ReadString('Main','CommPort','1'))  ;
	if(CommRecord.BaudRate = 9600) then CloseOmsCommHandle(CommRecord);
	if(InitOmsCommPort(Port)<> 0 ) Then
		ErrMsg := 'Comm Port Fail! ' ;
	sleep(100);
	if(Errmsg = '') Then
		if(SendAndGetString(CommRecord,'WY;',Response)<>0)Then
			ErrMsg := 'Indexer Init Fail!';
			MainForm.CmdBx.Items.Insert(0,Response );
//
	sleep(100);
	if(Errmsg = '') Then
		if(SendString
			(CommRecord,'RS;')<>0)
			Then ErrMsg := 'All Axis Init Fail!';
	sleep(5000);
	if(Errmsg = '') Then
		if(SendString
			(CommRecord,'EF; IO0,0; AX; DBI; LP0; SC; AY; DBI; LP0; SC; ')<>0)
			Then ErrMsg := 'All Axis Init Fail!';
//
	sleep(100);
	Ymaxaccel := 'ac' + (yacmax);
	Xmaxaccel := 'ac' + (xacmax);

	ymaxvl := 'vl' + yvlmax;
	xmaxvl :=  'vl' + xvlmax;

	initstring := 'AX vl100000 ac100000; AY ' +  ymaxvl + ' ' + Ymaxaccel + ' ;'  ;

	initstring := 'AX ' + xmaxvl + ' ' + xmaxaccel + '; Ay '+  ymaxvl + ' ' + Ymaxaccel + ' ;'  ;

	if(Errmsg = '') Then
		if(SendString
//			(CommRecord,'AX vl100000 ac100000; AY vl50000 ' + 'ac25000' + ';')<>0)
			(CommRecord,PChar(initstring))<>0)
			Then ErrMsg := 'Velocity and Acceleration Fail!';
//
	if(ErrMsg <> '') Then showmessage(Errmsg);
	if(errMsg <> '') Then MotorInit := False;
End;
